{
	"name": "gpn-test-senior",
	"version": "0.1.0",
	"private": true,
	"dependencies": {
		"@consta/icons": "1.1.0",
		"@consta/uikit": "5.6.1",
		"@types/node": "^16.18.71",
		"@types/react": "^18.2.48",
		"@types/react-dom": "^18.2.18",
		"ag-grid-enterprise": "33.0.3",
		"ag-grid-react": "33.0.3",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"react-scripts": "5.0.1",
		"react-virtuoso": "^4.12.0",
		"typescript": "^4.9.5"
	},
	"devDependencies": {
		"@conarti/eslint-plugin-feature-sliced": "^1.0.5",
		"husky": "^9.1.7",
		"json-server": "0.17.4",
		"lint-staged": "^16.3.1"
	},
	"scripts": {
		"start": "react-scripts start",
		"build": "react-scripts build",
		"test": "react-scripts test",
		"generate": "node server/generate-data.js",
		"server": "node server/generate-data.js && npx json-server --watch server/db.json --port 3001",
		"dev": "concurrently \"npm run server\" \"npm start\"",
		"prepare": "husky"
	},
	"lint-staged": {
		"src/**/*.{ts,tsx}": [
			"eslint --max-warnings=0"
		]
	},
	"eslintConfig": {
		"extends": [
			"react-app",
			"plugin:@conarti/feature-sliced/recommended"
		],
		"plugins": [
			"@conarti/feature-sliced"
		],
		"rules": {
			"import/order": "off"
		}
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	}
}
